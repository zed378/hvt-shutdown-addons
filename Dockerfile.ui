# Custom Harvester dashboard (fork with the add-on menus) built to be served as
# Harvester's `ui-index` (Settings -> UI -> ui-index, ui-source: External).
#
# NOTE: this builds the FULL dashboard (yarn build, RANCHER_ENV=harvester) — NOT
# `build-pkg`. build-pkg only emits an extension bundle to be loaded into a Rancher
# shell (the path that never cached on this Harvester). The ui-index needs the whole
# standalone dashboard (index.html + shell + assets).
#
# NO TLS HERE — on purpose. This container serves plain HTTP only:
#   * Harvester fetches the ui-index HTML server-side over cluster-internal DNS.
#   * The browser fetches the JS/CSS through Harvester's OWN ingress (the nginx
#     ingress on the VIP:443, path ASSET_PATH), so they are SAME-ORIGIN with the
#     Harvester UI and reuse the cert the operator already trusts. No self-signed
#     cert, no VIP baked in, and no certificate approval.

# ---- Stage 1: Build the full Harvester dashboard ----
FROM node:20 AS builder

WORKDIR /build
COPY harvester-ui-extension/ ./

# ASSET_PATH is where the browser fetches JS/CSS from, and MUST match the Ingress
# path in DashboardChart (uiDashboard.assetPath). It is host-RELATIVE on purpose:
# the page is served from Harvester's origin, so "/custom-dashboard/..." resolves to
# https://<harvester>/custom-dashboard/... — same origin, existing cert, no prompt.
# (An absolute URL here would hard-code the VIP and require its own certificate.)
#
# ROUTER_BASE stays /dashboard/ — that's the route Harvester serves the SPA at.
ARG ASSET_PATH=/custom-dashboard
RUN yarn --pure-lockfile install && \
    COMMIT=custom VERSION=v1.7-node-shutdown \
    OUTPUT_DIR=dist/hosted \
    ROUTER_BASE=/dashboard/ \
    RESOURCE_BASE=${ASSET_PATH} \
    RANCHER_ENV=harvester \
    NODE_OPTIONS=--max-old-space-size=7168 \
    yarn run build

# ---- Stage 2: Serve over plain HTTP with nginx ----
FROM nginx:1.27-alpine
ARG ASSET_PATH=/custom-dashboard

RUN rm -rf /etc/nginx/conf.d/default.conf /usr/share/nginx/html/*

# Serve the bundle under ASSET_PATH on plain HTTP:8080. Reached two ways:
#   1. Harvester (server-side)  -> http://<svc>.<ns>.svc:8080${ASSET_PATH}/index.html
#   2. The browser (assets)     -> https://<harvester-vip>${ASSET_PATH}/js/... via the Ingress
RUN printf '%s\n' \
    'server {' \
    '    listen 8080;' \
    '    server_name _;' \
    '    root /usr/share/nginx/html;' \
    '    absolute_redirect off;' \
    '' \
    '    # The dashboard is loaded cross-context by Harvester; keep this permissive.' \
    '    add_header Access-Control-Allow-Origin  *;' \
    '    add_header Access-Control-Allow-Methods '"'"'GET, OPTIONS'"'"';' \
    '' \
    '    location /healthz {' \
    '        access_log off;' \
    '        return 200 '"'"'ok'"'"';' \
    '        add_header Content-Type text/plain;' \
    '    }' \
    '' \
    "    location ${ASSET_PATH}/ {" \
    '        alias /usr/share/nginx/html/;' \
    "        try_files \$uri \$uri/ ${ASSET_PATH}/index.html;" \
    '    }' \
    '' \
    "    location = / { return 302 ${ASSET_PATH}/; }" \
    '}' \
    > /etc/nginx/conf.d/default.conf

COPY --from=builder /build/dist/hosted/ /usr/share/nginx/html/

# Drop source maps — dev-only and unneeded in production.
RUN find /usr/share/nginx/html -name '*.js.map' -delete

# Run nginx UNPRIVILEGED (uid 101). Pre-own everything nginx writes so it never
# needs to chown at startup: the pod drops ALL capabilities (no CAP_CHOWN), and a
# root master would fail with:
#   [emerg] chown("/var/cache/nginx/client_temp", 101) failed (Operation not permitted)
# Port 8080 is unprivileged, so no root is required at all.
RUN chown -R nginx:nginx /usr/share/nginx/html /var/cache/nginx /var/log/nginx && \
    touch /var/run/nginx.pid && chown nginx:nginx /var/run/nginx.pid

USER 101

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
