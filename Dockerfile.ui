# ---- Stage 1: Build UI plugin static files ----
FROM node:24-slim AS builder

WORKDIR /build

# Copy UI plugin source
COPY hvt-shutdown-ui/ ./

# Install dependencies and build the UI extension package
# Remove .yarnrc frozen-lockfile constraint (lockfile may differ across platforms)
RUN rm -f .yarnrc && \
    yarn install && \
    yarn build-pkg hvt-shutdown-ui true

# ---- Stage 2: Serve static files with nginx ----
FROM nginx:1.27-alpine

# Remove default nginx config and html
RUN rm -rf /etc/nginx/conf.d/default.conf /usr/share/nginx/html/*

# Copy custom nginx configuration
COPY <<'NGINX_CONF' /etc/nginx/conf.d/default.conf
server {
    listen 8080;
    server_name _;

    root /usr/share/nginx/html;
    index package.json;

    # Serve static files with caching.
    # NOTE: wildcard CORS is required so the Rancher/Harvester dashboard can load
    # this extension bundle cross-origin from the UIPlugin endpoint.
    location / {
        try_files $uri $uri/ =404;
        add_header Access-Control-Allow-Origin *;
        add_header X-Content-Type-Options "nosniff";
        add_header Cache-Control "public, max-age=3600";
    }

    # Health check endpoint
    location /healthz {
        access_log off;
        return 200 '{"status":"ok"}';
        add_header Content-Type application/json;
    }
}
NGINX_CONF

# Serve the extension bundle at the web ROOT.
# `yarn build-pkg` emits dist-pkg/<name>-<version>/ containing the umd bundle and
# its package.json. We flatten THAT directory's contents into the web root so the
# manifest's "main" (e.g. hvt-shutdown-ui-1.2.0.umd.min.js) resolves at
# <endpoint>/<main>. Rancher reads <endpoint>/package.json and then fetches "main"
# relative to the endpoint root; if the JS lives in a subdirectory it 404s and the
# UIPlugin is silently never cached (STATE stays empty). Flattening fixes that.
COPY --from=builder /build/dist-pkg/ /tmp/dist-pkg/
RUN VERSION_DIR=$(ls -d /tmp/dist-pkg/hvt-shutdown-ui-*/ 2>/dev/null | head -1) && \
    if [ -z "$VERSION_DIR" ]; then echo "ERROR: No versioned build dir found"; exit 1; fi && \
    cp -a "${VERSION_DIR}." /usr/share/nginx/html/ && \
    rm -rf /tmp/dist-pkg && \
    echo "Serving flattened extension bundle:" && ls -1 /usr/share/nginx/html

EXPOSE 8080

# Run nginx as non-root
RUN chown -R nginx:nginx /usr/share/nginx/html && \
    chown -R nginx:nginx /var/cache/nginx && \
    chown -R nginx:nginx /var/log/nginx && \
    touch /var/run/nginx.pid && \
    chown nginx:nginx /var/run/nginx.pid

USER 101

CMD ["nginx", "-g", "daemon off;"]
